# Copy to .env and adjust. Never commit .env.

# Postgres
POSTGRES_DB=verita
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Role passwords (dev-only defaults; rotate in prod)
APP_ROLE_PASSWORD=app_pass
MIGRATOR_ROLE_PASSWORD=migrator_pass

# Django
DJANGO_SECRET_KEY=dev-secret-do-not-use-in-prod-please-replace
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Webhook signing (HMAC-SHA256 over `<timestamp>.<body>`)
# REPLACE before any non-local use — an unchanged value makes webhooks forgeable.
WEBHOOK_SECRET_CURRENT=CHANGE-ME-dev-only-not-a-real-secret
WEBHOOK_SECRET_PREVIOUS=

# CORS + CSRF trusted origins (the two SPA origins in dev)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:8000
